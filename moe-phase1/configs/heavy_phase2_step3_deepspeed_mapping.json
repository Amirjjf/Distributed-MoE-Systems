{
  "seed": 42,
  "train_steps": 1500,
  "log_every": 20,

  "vocab_size": 32000,
  "seq_len": 1024,
  "micro_batch_size": 2,

  "hidden_size": 1024,
  "num_layers": 8,

  "num_experts": 32,
  "top_k": 2,

  "lr": 0.0001,
  "weight_decay": 0.01,
  "grad_clip": 1.0,

  "precision": "bf16",
  "use_deepspeed_moe": true,
  "deepspeed_ep_size": 0,
  "deepspeed_enable_mapped_experts": true,
  "deepspeed_allow_rebuild_on_rebalance": false,
  "deepspeed_rebalance_mode": "save_next_requires_restart",
  "deepspeed_initial_map_path": null,
  "moe_aux_loss_coef": 0.01,

  "enable_rebalance_planner": true,
  "rebalance_eval_interval": 20,
  "rebalance_history_size": 8,
  "rebalance_threshold": 0.05,
  "rebalance_metric": "wasted_fraction",
  "rebalance_min_steps": 100,
  "rebalance_cooldown": 120,
  "rebalance_use_ema": true,
  "rebalance_ema_beta": 0.85,
  "rebalance_dry_run": false,
  "rebalance_apply_live_fallback": true,
  "rebalance_log_remote_stats": true,
  "rebalance_min_expected_improvement": 0.0
}
